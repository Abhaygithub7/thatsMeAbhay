<style>
/* Library Card Theme Styles */
.library-card[data-color=indigo] {
  background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
  --card-tint: var(--color-pink-2);
}
.library-card[data-color=teal] {
  background: linear-gradient(135deg, #0f766e 0%, #0891b2 100%);
  --card-tint: var(--color-teal-3);
}
.library-card[data-color=green] {
  background: linear-gradient(135deg, #15803d 0%, #4d7c0f 100%);
  --card-tint: var(--color-green-2);
}
.library-card[data-color=orange] {
  background: linear-gradient(135deg, #c2410c 0%, #b45309 100%);
  --card-tint: var(--color-orange-2);
}

/* Show only the ASCII art that matches the data-color */
.library-card pre {
  display: none;
}
.library-card[data-color=indigo] pre[data-for=indigo] { display: block; }
.library-card[data-color=teal] pre[data-for=teal] { display: block; }
.library-card[data-color=green] pre[data-for=green] { display: block; }
.library-card[data-color=orange] pre[data-for=orange] { display: block; }

.signature-clear {
  transition: opacity 0.22s var(--ease-out-soft);
}
.signature-clear[data-show] {
  opacity: 1;
}
</style>

<script type="module" is:inline>
(function() {
  function initSignaturePad() {
    const card = document.getElementById("library-card");
    const canvas = document.querySelector("[data-signature-pad]");
    const clearBtn = document.querySelector("[data-signature-clear]");
    const eraserPreview = document.querySelector("[data-eraser-preview]");
    if (!card || !canvas) return;

    const ctx = canvas.getContext("2d");
    let isDrawing = false;
    let hasDrawn = false;
    let drawTool = "pen"; // "pen" or "eraser"
    
    // Set exact dimensions to prevent scaling fuzziness
    function resizeCanvas() {
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width;
      canvas.height = rect.height;
      
      // Draw signature fallback / restore if needed, or clean canvas
      ctx.lineCap = "round";
      ctx.lineJoin = "round";
    }
    
    resizeCanvas();
    window.addEventListener("resize", resizeCanvas);

    // Calligraphy drawing physics (variables)
    let lastX = 0, lastY = 0;
    let lastTime = 0;
    let lastWidth = 2.5;

    function getMousePos(e) {
      const rect = canvas.getBoundingClientRect();
      const clientX = e.touches ? e.touches[0].clientX : e.clientX;
      const clientY = e.touches ? e.touches[0].clientY : e.clientY;
      return {
        x: clientX - rect.left,
        y: clientY - rect.top
      };
    }

    function startDrawing(e) {
      if (e.button && e.button !== 0) return;
      isDrawing = true;
      const pos = getMousePos(e);
      lastX = pos.x;
      lastY = pos.y;
      lastTime = performance.now();
      lastWidth = drawTool === "pen" ? 2.5 : 24;

      ctx.beginPath();
      ctx.moveTo(lastX, lastY);
      
      if (drawTool === "eraser") {
        ctx.globalCompositeOperation = "destination-out";
        ctx.lineWidth = 24;
      } else {
        ctx.globalCompositeOperation = "source-over";
        ctx.strokeStyle = "#ffffff";
        ctx.lineWidth = lastWidth;
      }
      
      drawMove(e);
    }

    function drawMove(e) {
      if (!isDrawing) return;
      const pos = getMousePos(e);
      const now = performance.now();
      const dx = pos.x - lastX;
      const dy = pos.y - lastY;
      const dist = Math.hypot(dx, dy);
      const dt = now - lastTime || 1;
      const speed = dist / dt;

      if (drawTool === "pen") {
        // Calligraphy effect: faster draws = thinner strokes, slower draws = thicker strokes
        let targetWidth = Math.max(1.2, Math.min(3.6, 3.5 - speed * 0.8));
        // Interpolate stroke width changes
        ctx.lineWidth = lastWidth + (targetWidth - lastWidth) * 0.18;
        lastWidth = ctx.lineWidth;
      } else {
        ctx.lineWidth = 24; // Eraser size constant
      }

      ctx.lineTo(pos.x, pos.y);
      ctx.stroke();
      
      // Update historical markers
      lastX = pos.x;
      lastY = pos.y;
      lastTime = now;

      hasDrawn = true;
      if (clearBtn) clearBtn.setAttribute("data-show", "");
    }

    function stopDrawing() {
      isDrawing = false;
      ctx.closePath();
    }

    // Pointer events binding
    canvas.addEventListener("pointerdown", startDrawing);
    canvas.addEventListener("pointermove", drawMove);
    canvas.addEventListener("pointerup", stopDrawing);
    canvas.addEventListener("pointercancel", stopDrawing);
    
    // Touch events for mobile compatibility
    canvas.addEventListener("touchstart", (e) => {
      e.preventDefault();
      startDrawing(e);
    }, { passive: false });
    canvas.addEventListener("touchmove", (e) => {
      e.preventDefault();
      drawMove(e);
    }, { passive: false });
    canvas.addEventListener("touchend", stopDrawing, { passive: true });

    // Eraser preview indicator tracking
    canvas.addEventListener("pointermove", (e) => {
      if (drawTool === "eraser" && eraserPreview) {
        const pos = getMousePos(e);
        eraserPreview.style.transform = `translate3d(${pos.x - 12}px, ${pos.y - 12}px, 0)`;
        eraserPreview.style.width = "24px";
        eraserPreview.style.height = "24px";
        eraserPreview.classList.remove("hidden");
      }
    });

    canvas.addEventListener("pointerleave", () => {
      if (eraserPreview) eraserPreview.classList.add("hidden");
    });

    // Clear operation
    if (clearBtn) {
      clearBtn.addEventListener("click", () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        hasDrawn = false;
        clearBtn.removeAttribute("data-show");
      });
    }

    // Connect Tool Toggle events
    window.addEventListener("card:tool-change", (e) => {
      drawTool = e.detail.tool; // "pen" or "eraser"
      if (canvas) {
        canvas.setAttribute("data-cursor", drawTool);
      }
    });

    // Save Base64 utility listener
    window.addEventListener("card:request-signature", () => {
      const dataUrl = canvas.toDataURL("image/png");
      window.dispatchEvent(new CustomEvent("card:signature-ready", {
        detail: { dataUrl: dataUrl, hasDrawn: hasDrawn }
      }));
    });
  }

  initSignaturePad();
  document.addEventListener("astro:page-load", initSignaturePad);
})();
</script>
