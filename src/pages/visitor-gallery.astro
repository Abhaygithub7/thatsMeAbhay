              <div class="stats-color-bar h-full rounded-[6px] transition-all duration-700 ease-out" style="width: ${pct}%; background: ${meta.color}; opacity: 0.85;"></div>
            </div>
            <span class="stats-color-pct font-mono text-xs text-[var(--color-ink-dim)] w-12 text-left tabular-nums transition-colors">
