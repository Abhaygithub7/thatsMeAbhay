---
import { ClientRouter } from 'astro:transitions';
import Sidebar from '../components/Sidebar.astro';
import CustomCursor from '../components/CustomCursor.astro';
import SparkBurst from '../components/SparkBurst.astro';
import SitePet from '../components/SitePet.astro';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="View cards left by visitors who stopped by Abhay's World.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@300;400;500;600&family=Outfit:wght@200;300;400;500&family=Inter:wght@300;400;500&display=swap">
  <title>Visitor Gallery — Abhay's World</title>
  
  <script is:inline define:vars={{
    firebaseConfig: {
      apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
      authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
      projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
      storageBucket: import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
      messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
      appId: import.meta.env.PUBLIC_FIREBASE_APP_ID
    }
  }}>
    if (firebaseConfig.apiKey) {
      window.firebaseConfig = firebaseConfig;
    }
  </script>
  <script src="/js/db.js" is:inline></script>
  <ClientRouter />
  
  <style is:global>
    /* Mini Card layout grids in the gallery */
    .mini-card-wrap {
      container-type: inline-size;
      width: 100%;
      aspect-ratio: 388 / 252;
      overflow: hidden;
      overflow: clip;
      overflow-clip-margin: 18px;
      transition: transform 0.42s cubic-bezier(0.34, 1.56, 0.64, 1);
      content-visibility: auto;
      contain-intrinsic-size: auto 252px;
      perspective: 800px;
    }
    .mini-card-wrap:hover, .mini-card-wrap[data-tilting] {
      content-visibility: visible;
      overflow: visible;
      transform-style: preserve-3d;
      will-change: transform;
    }
    .mini-card-wrap[data-tilting] {
      transition: none;
    }
    .mini-card-wrap .mini-card {
      position: absolute;
      top: 0;
      left: 0;
      width: 388px;
      height: 252px;
      transform-origin: top left;
      transform: scale(var(--mini-card-scale, tan(atan2(100cqi, 388px)))) rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
      transition: box-shadow 0.28s cubic-bezier(0.22, 1, 0.36, 1), transform 0.1s ease-out;
    }
    .mini-card-wrap:hover .mini-card {
      box-shadow: 0 24px 48px -12px rgba(0, 0, 0, 0.35), 0 8px 18px -6px rgba(0, 0, 0, 0.22);
    }
    .mini-gloss {
      background: radial-gradient(180px 180px at var(--gloss-x, 50%) var(--gloss-y, 50%), rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0) 70%);
      opacity: 0;
      transition: opacity 0.3s ease;
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 20;
    }
    .mini-card-wrap:hover .mini-gloss {
      opacity: 1;
      mix-blend-mode: soft-light;
    }
    
    .mini-card[data-color=indigo],
    .library-card[data-color=indigo],
    [data-modal-card][data-color=indigo] {
      background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
      --tint: var(--color-pink-2);
      --card-border: rgba(167, 139, 250, 0.5);
    }
    .mini-card[data-color=teal],
    .library-card[data-color=teal],
    [data-modal-card][data-color=teal] {
      background: linear-gradient(135deg, #0f766e 0%, #0891b2 100%);
      --tint: var(--color-teal-3);
      --card-border: rgba(45, 212, 191, 0.5);
    }
    .mini-card[data-color=green],
    .library-card[data-color=green],
    [data-modal-card][data-color=green] {
      background: linear-gradient(135deg, #15803d 0%, #4d7c0f 100%);
      --tint: var(--color-green-2);
      --card-border: rgba(134, 239, 172, 0.5);
    }
    .mini-card[data-color=orange],
    .library-card[data-color=orange],
    [data-modal-card][data-color=orange] {
      background: linear-gradient(135deg, #c2410c 0%, #b45309 100%);
      --tint: var(--color-orange-2);
      --card-border: rgba(253, 186, 116, 0.5);
    }

    /* Show only the ASCII art that matches the data-color */
    .mini-card pre {
      display: none;
    }
    .mini-card[data-color=indigo] pre[data-for=indigo] { display: block; }
    .mini-card[data-color=teal] pre[data-for=teal] { display: block; }
    .mini-card[data-color=green] pre[data-for=green] { display: block; }
    .mini-card[data-color=orange] pre[data-for=orange] { display: block; }

    /* Details Stats Panel Accordion heights */
    .stats-body-wrap {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.42s cubic-bezier(0.22, 1, 0.36, 1);
    }
    details[open] .stats-body-wrap {
      grid-template-rows: 1fr;
    }
    .stats-body {
      overflow: hidden;
      min-height: 0;
    }
    .stats-toggle__chevron {
      transition: transform 0.3s var(--ease-out-soft);
    }
    details[open] .stats-toggle__chevron {
      transform: rotate(180deg);
    }
    details[data-collapsing] .stats-toggle__chevron {
      transform: rotate(0deg);
    }

    /* Color picker filters stats styling */
    .stats-color-row {
      padding: 6px 8px;
      margin: -2px -8px;
      transition: opacity 0.22s var(--ease-out-soft), background 0.22s var(--ease-out-soft);
    }
    .stats-color-row:hover .stats-color-bar {
      opacity: 1 !important;
    }
    .stats-color-row:hover .stats-color-pct {
      color: var(--color-ink);
    }
    [data-stats-color-rows]:has(.stats-color-row:hover) .stats-color-row:not(:hover) {
      opacity: 0.5;
    }
    [data-stats-color-rows]:has(.stats-color-row[data-active]) .stats-color-row:not([data-active]) {
      opacity: 0.5;
    }
    .stats-color-row[data-active] {
      opacity: 1 !important;
      background: rgba(195, 186, 156, 0.2);
    }
    .stats-color-row[data-active] .stats-color-bar {
      opacity: 1 !important;
    }
    .stats-color-row[data-active] .stats-color-pct {
      color: var(--color-ink);
    }

    /* Grid Filter Hide styling */
    [data-gallery-grid] [data-mini-card-wrap] {
      transition: opacity 0.28s var(--ease-out-soft), transform 0.28s var(--ease-out-soft);
    }
    [data-gallery-grid] [data-mini-card-wrap][data-filter-hide] {
      display: none;
    }

    .gallery-shuffle[data-spinning] svg {
      animation: gallery-shuffle-spin .6s cubic-bezier(.34,1.56,.64,1);
    }
    @keyframes gallery-shuffle-spin {
      0% { transform: rotate(0); }
      to { transform: rotate(360deg); }
    }

    /* Full Detail Modal Popup */
    .gallery-detail {
      background-color: rgba(234, 230, 219, 0.95);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transition: opacity 0.35s var(--ease-out-soft);
    }
    .gallery-detail[data-open] {
      opacity: 1;
      pointer-events: auto;
    }

    @media (prefers-reduced-motion: reduce) {
      .mini-card-wrap, .mini-card, .stats-body-wrap, .gallery-shuffle[data-spinning] svg {
        transition: none !important;
        animation: none !important;
      }
    }
  </style>
</head>
<body class="bg-[var(--color-bg)] text-[var(--color-ink)] font-body selection:bg-[var(--color-bg-neutral)]">
  <div class="flex flex-col lg:flex-row items-stretch min-h-screen">
    
    <!-- Sidebar navigation -->
    <Sidebar activeSection="gallery" />

    <!-- Main Workspace Area -->
    <main class="flex flex-col gap-6 sm:gap-8 p-6 md:p-12 flex-1 min-w-0">
      
      <!-- Gallery Header -->
      <header class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 md:gap-6">
        <div class="flex items-end gap-3 sm:gap-4 flex-wrap">
          <h1 class="font-display font-light text-[28px] sm:text-[32px] md:text-[36px] leading-none text-[var(--color-ink)]">
            Visitor Gallery
          </h1>
          <p data-gallery-subtitle class="font-mono text-sm sm:text-base uppercase text-[var(--color-ink-dim)] mb-1">
            Loading guests...
          </p>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <button type="button" data-shuffle class="gallery-shuffle bg-[var(--color-bg-neutral)] rounded-[4px] px-2.5 py-1 flex items-center gap-2 font-mono text-sm uppercase text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] hover:bg-[var(--color-bg-neutral-2)] transition-colors cursor-pointer select-none">
            Shuffle
            <svg class="transition-transform duration-200" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 3h5v5"></path>
              <path d="M4 20L21 3"></path>
              <path d="M21 16v5h-5"></path>
              <path d="M15 15l6 6"></path>
              <path d="M4 4l5 5"></path>
            </svg>
          </button>
        </div>
      </header>

      <!-- Stats Accordion Details Panel -->
      <details data-stats-panel class="stats-panel mt-2 w-full">
        <summary class="stats-toggle bg-[var(--color-bg-neutral)] rounded-[8px] px-3 py-2 flex items-center justify-between gap-2 font-mono text-xs uppercase text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] hover:bg-[var(--color-bg-neutral-2)] transition-colors cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
          <span class="flex items-center gap-2">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
            Stats for Nerds
          </span>
          <svg class="stats-toggle__chevron transition-transform duration-200" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6"></path>
          </svg>
        </summary>
        <div class="stats-body-wrap">
          <div class="stats-body rounded-[12px] border border-[var(--color-bg-neutral-2)] bg-[var(--color-bg-neutral)]/40 mt-4 p-4 sm:p-6 flex flex-col gap-6">

            <!-- KPI metrics row -->
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" data-stats-kpi-grid>
              <!-- Filled dynamically by JS -->
            </div>

            <!-- Dynamic Line Graph of Signups over Time -->
            <div data-stats-timeline></div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              
              <!-- Color Picks Bar chart -->
              <div>
                <h3 class="font-mono text-xs uppercase text-[var(--color-ink-dim)] mb-3 tracking-wide">Card Color Picks</h3>
                <div class="flex flex-col gap-2" data-stats-color-rows>
                  <!-- Generated dynamically by JS -->
                </div>
                <button type="button" data-stats-filter-reset class="font-mono text-[11px] uppercase text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] transition-all mt-3 cursor-pointer items-center gap-1.5 ml-[76px]" style="display: none">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block align-middle mr-1">
                    <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                    <path d="M3 3v5h5"></path>
                  </svg>
                  Show all
                </button>
              </div>
              
              <!-- Favorite Hats picks -->
              <div class="stats-card rounded-[8px] bg-[var(--color-bg-neutral)]/60 border border-[var(--color-bg-neutral-2)]/60 p-3">
                <p class="font-mono text-xs uppercase text-[var(--color-ink-dim)] mb-2">Favorite Hat</p>
                <div class="flex gap-4 flex-wrap" data-stats-hats>
                  <!-- Hat list details populated dynamically -->
                </div>
              </div>
            </div>
          </div>
        </div>
      </details>

      <!-- Signature guestbook link button -->
      <a href="/onboarding?from=gallery" data-gallery-signin-btn class="flex items-center justify-center gap-2 rounded-[12px] bg-[var(--color-ink)] px-4 py-3.5 font-mono text-sm uppercase text-[var(--color-bg)] hover:bg-[var(--color-ink-dim)] transition-colors select-none">
        Sign the guestbook
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14"></path>
          <path d="M5 12h14"></path>
        </svg>
      </a>

      <!-- Grid displaying visitor cards (Max 15 displayed) -->
      <div data-gallery-grid class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-y-8 gap-x-6 mt-4 select-none">
        <!-- Javascript renders cards directly into this container -->
      </div>

    </main>
  </div>

  <!-- Fullscreen card details modal overlay -->
  <div data-detail-modal class="gallery-detail fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity">
    <div class="absolute inset-0 z-0 cursor-pointer bg-[var(--color-bg)]/80 backdrop-blur-md" data-close-backdrop></div>
    
    <div class="relative z-10 w-[388px] max-w-full aspect-[388/252] rounded-[24px] shadow-2xl transition-transform duration-300 scale-95 flex flex-col p-7 text-white font-mono uppercase border border-black/10 select-none overflow-hidden" data-modal-card>
      <div class="flex justify-between items-center z-10">
        <h3 class="font-display font-light text-[24px] leading-none normal-case">Developer Card</h3>
        <button type="button" data-close-modal class="text-2xl leading-none font-mono text-white/80 hover:text-white cursor-pointer select-none">×</button>
      </div>
      
      <dl class="mt-6 flex flex-col gap-2 relative z-10">
        <div class="flex flex-col">
          <dt class="text-[11px] opacity-70" data-modal-tint>Visitor Name</dt>
          <dd class="text-[17px] mt-1" data-modal-name>Name</dd>
        </div>
        <div class="flex flex-col mt-2">
          <dt class="text-[11px] opacity-70" data-modal-tint>Issued on</dt>
          <dd class="text-[17px] mt-1" data-modal-date>Date</dd>
        </div>
      </dl>

      <div class="mt-auto flex items-end justify-between relative z-10">
        <p class="text-[12px] opacity-70" data-modal-number>No. 0000</p>
        <div class="flex items-end gap-2 grow ml-8">
          <span class="text-[18px] leading-none">x</span>
          <span class="block flex-1 border-b border-white/50 mb-1"></span>
        </div>
      </div>
      
      <!-- Canvas image signatures -->
      <img src="" alt="" class="absolute inset-0 size-full pointer-events-none z-10 select-none" data-modal-signature>
      
      <!-- ASCII graphic art template -->
      <pre data-modal-ascii class="absolute pointer-events-none whitespace-pre select-none font-mono text-[14px] leading-[1.08] right-[-24px] bottom-[-14px] opacity-50 z-0"></pre>
    </div>
  </div>

  <!-- Custom Cursor, Sparks & Site Pet widgets -->
  <CustomCursor />
  <SparkBurst />
  <SitePet />

  <script type="module" is:inline>
    (function() {
      // HTML entity escaping to prevent XSS from user-supplied data
      function esc(str) {
        const el = document.createElement("span");
        el.textContent = String(str);
        return el.innerHTML;
      }

      const grid = document.querySelector("[data-gallery-grid]");
      const modal = document.querySelector("[data-detail-modal]");
      const closeBtn = document.querySelector("[data-close-modal]");
      const backdrop = document.querySelector("[data-close-backdrop]");
      const modalCard = document.querySelector("[data-modal-card]");
      const shuffleBtn = document.querySelector("[data-shuffle]");

      const ASCII_PRESETS = {
        indigo: `⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⢔⣶⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⡼⠗⡿⣾⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⡼⠓⡞⢩⣯⡀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣀⣀⣀⣀⠀⠀⠀⠀⠀⠀⠀⠰⡹⠁⢰⠃⣩⣿⡇⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠘⢷⣿⠿⣉⣩⠛⠲⢶⡠⢄⠐⣣⠃⣰⠗⠋⢀⣯⠁⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠙⣯⣠⠬⠦⢤⣀⠈⠓⢽⣾⢔⣡⡴⠞⠻⠙⢳⡄`,
        teal: `⠀⠀⠀⢸⣦⡀⠀⠀⠀⠀⢀⡄⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⢸⣏⠻⣶⣤⡶⢾⡿⠁⠀⢠⣄⡀⢀⣴⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⣀⣼⠷⠀⠀⠁⢀⣿⠃⠀⠀⢀⣿⣿⣿⣇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠴⣾⣯⣅⣀⠀⠀⠀⠈⢻⣦⡀⠒⠻⠿⣿⡿⠿⠓⠂⠀⠀⢀⡇⠀⠀⠀⠀⠀⠀⠀`,
        green: `⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣤⠴⢤⡀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣠⢾⣛⡆⠈⡏⠰⠶⠃⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢦⣿⣄⣉⣁⣤⠽⣦⣤⡶⠶⣤⣄⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠉⠚⠹⡉⢃⣴⠟⠉⠀⠀⠀⠀⠉⠻`,
        orange: `⠀⠀⠀⣀⣤⣤⣤⣤⣀⣀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⣰⣿⣿⠿⢿⣿⣿⣿⣿⣿⣷⣦⣀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣠
⣰⣿⣿⡟⠀⠀⠈⠙⠛⠿⣿⣿⣿⣿⣿⣶⣄⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣴⣿⣿
⣿⣿⣿⠁⠀⠀⠀⠀⠀⠀⠀⠈⠙⠛⠿⢿⣿⣿⣦⣀⠀⠀⠀⠀⠀⠀⢀⣴⣿⡿⠛⠁`
      };

      let activeFilterColor = null;
      let allCardsData = [];
      let isFiltering = false;

      // Relative time calculator helper
      function getRelativeTime(timestamp) {
        if (!timestamp) return "--";
        const date = new Date(timestamp);
        const now = new Date();
        const diffMs = now - date;
        const diffMin = Math.round(diffMs / 60000);
        const diffHr = Math.round(diffMs / 3600000);
        const diffDay = Math.round(diffMs / 86400000);

        if (diffMin < 1) return "Just now";
        if (diffMin < 60) return `${diffMin}min ago`;
        if (diffHr < 24) return `${diffHr}h ago`;
        return `${diffDay}d ago`;
      }

      // Compute rich KPI stats from full cards dataset
      function computeStats(cards) {
        const now = new Date();

        // Total count
        const total = cards.length;

        // New this week (last 7 days)
        const weekAgo = new Date(now - 7 * 86400000);
        const newThisWeek = cards.filter(c => new Date(c.timestamp || c.date) >= weekAgo).length;

        // New this month (last 30 days)
        const monthAgo = new Date(now - 30 * 86400000);
        const newThisMonth = cards.filter(c => new Date(c.timestamp || c.date) >= monthAgo).length;

        // Build per-day counts map (YYYY-MM-DD)
        const dayCounts = new Map();
        cards.forEach(c => {
          const d = new Date(c.timestamp || c.date);
          if (isNaN(d)) return;
          const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
          dayCounts.set(key, (dayCounts.get(key) || 0) + 1);
        });

        // Peak day (most signups)
        let peakDay = null, peakCount = 0;
        dayCounts.forEach((count, day) => {
          if (count > peakCount) { peakCount = count; peakDay = day; }
        });
        const peakLabel = peakDay
          ? new Date(peakDay + 'T12:00:00Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
          : '--';

        // Busiest day of week
        const dowCounts = [0,0,0,0,0,0,0];
        cards.forEach(c => {
          const d = new Date(c.timestamp || c.date);
          if (!isNaN(d)) dowCounts[d.getDay()]++;
        });
        const DOW_NAMES = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        const busiestDow = cards.length > 0 ? DOW_NAMES[dowCounts.indexOf(Math.max(...dowCounts))] : '--';

        // All-time streak (consecutive days with ≥1 visitor)
        const sortedDays = Array.from(dayCounts.keys()).sort();
        let streak = 0, maxStreak = 0, prevDay = null;
        sortedDays.forEach(dayStr => {
          const d = new Date(dayStr + 'T12:00:00Z');
          if (prevDay) {
            const diff = Math.round((d - prevDay) / 86400000);
            if (diff === 1) { streak++; } else { streak = 1; }
          } else { streak = 1; }
          maxStreak = Math.max(maxStreak, streak);
          prevDay = d;
        });

        // Average visitors per active day
        const activeDays = dayCounts.size;
        const avgPerDay = activeDays > 0 ? (total / activeDays).toFixed(1) : '0';

        // Latest guest name + time
        const latestCard = cards[0];
        const latestTime = latestCard ? getRelativeTime(latestCard.timestamp || latestCard.date) : '--';
        const latestName = latestCard ? latestCard.name : '--';

        return { total, newThisWeek, newThisMonth, peakLabel, peakCount, busiestDow, maxStreak, avgPerDay, latestTime, latestName, activeDays };
      }

