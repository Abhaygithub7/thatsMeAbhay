      // Filter transitions with Web Animations API (FLIP transitions)
      function executeGridFilter(color) {
        if (isFiltering) return;
        isFiltering = true;

        const resetBtn = document.querySelector("[data-stats-filter-reset]");
        const wraps = Array.from(grid.querySelectorAll("[data-mini-card-wrap]"));
        
        if (resetBtn) {
          resetBtn.style.display = color ? "inline-flex" : "none";
        }

        const isReducedMotion = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches;
        const fadeOutDuration = isReducedMotion ? 0 : 180;
        const flipDuration = isReducedMotion ? 0 : 380;

        const isCardMatches = (cardWrap) => !color || cardWrap.dataset.color === color;
        const previouslyVisible = wraps.filter(w => !w.hasAttribute("data-filter-hide"));
        const cardsToHide = previouslyVisible.filter(w => !isCardMatches(w));
        const cardsToShow = wraps.filter(w => w.hasAttribute("data-filter-hide") && isCardMatches(w));
        const cardsToKeep = previouslyVisible.filter(w => isCardMatches(w));

        // Record initial positions for visible remaining cards
        const initialRects = new Map();
        cardsToKeep.forEach(w => {
          initialRects.set(w, w.getBoundingClientRect());
        });

        function applyDOMFilters() {
          wraps.forEach(w => {
            if (isCardMatches(w)) {
              w.removeAttribute("data-filter-hide");
            } else {
              w.setAttribute("data-filter-hide", "");
            }
          });

          // Play FLIP and fade in transitions
          let pendingAnimations = 0;
          const checkDone = () => {
            pendingAnimations--;
            if (pendingAnimations <= 0) {
              isFiltering = false;
            }
          };

          // FLIP remaining cards
          cardsToKeep.forEach(w => {
            const start = initialRects.get(w);
            const end = w.getBoundingClientRect();
            if (start) {
              const dx = start.left - end.left;
              const dy = start.top - end.top;
              if (Math.abs(dx) > 1 || Math.abs(dy) > 1) {
                pendingAnimations++;
                const anim = w.animate([
                  { transform: `translate3d(${dx}px, ${dy}px, 0)` },
                  { transform: "translate3d(0, 0, 0)" }
                ], {
                  duration: flipDuration,
                  easing: "cubic-bezier(0.22, 1, 0.36, 1)"
                });
                anim.onfinish = checkDone;
              }
            }
          });

          // Fade/Scale in newly shown cards
          cardsToShow.forEach(w => {
            pendingAnimations++;
            const anim = w.animate([
              { opacity: 0, transform: "scale3d(0.92, 0.92, 1)" },
              { opacity: 1, transform: "scale3d(1, 1, 1)" }
            ], {
              duration: flipDuration,
              easing: "cubic-bezier(0.22, 1, 0.36, 1)"
            });
            anim.onfinish = checkDone;
          });

          if (pendingAnimations === 0) {
            isFiltering = false;
          }
        }

        // Fade/Scale out hidden cards first
        if (cardsToHide.length === 0) {
          applyDOMFilters();
        } else {
          let hidesRemaining = cardsToHide.length;
          cardsToHide.forEach(w => {
            const anim = w.animate([
              { opacity: 1, transform: "scale3d(1, 1, 1)" },
              { opacity: 0, transform: "scale3d(0.92, 0.92, 1)" }
            ], {
              duration: fadeOutDuration,
              easing: "ease-out"
            });
            anim.onfinish = () => {
              hidesRemaining--;
              if (hidesRemaining === 0) {
                applyDOMFilters();
              }
            };
          });
        }
      }

      function applyFilter(color) {
        activeFilterColor = color;
        // Highlight active filter row
        const rows = document.querySelectorAll("[data-stats-color-filter]");
        rows.forEach(r => {
          r.toggleAttribute("data-active", r.dataset.statsColorFilter === color);
        });
        executeGridFilter(color);
      }

      function resetFilter() {
        activeFilterColor = null;
        const rows = document.querySelectorAll("[data-stats-color-filter]");
        rows.forEach(r => r.removeAttribute("data-active"));
        executeGridFilter(null);
      }

      // 3D Tilt and radial gloss calculation handler
      function handleCardPointerMove(e, wrap) {
        const card = wrap.querySelector(".mini-card");
        if (!card) return;

        const rect = wrap.getBoundingClientRect();
        const width = rect.width;
        const height = rect.height;
        const mouseX = e.clientX - (rect.left + width / 2);
        const mouseY = e.clientY - (rect.top + height / 2);

        // Rotation angles limits (e.g. 9 degrees max)
        const maxTilt = 9;
        const tiltX = (mouseY / (height / 2)) * maxTilt;
        const tiltY = -(mouseX / (width / 2)) * maxTilt;

        // Gloss percentage coordinates
        const glossX = ((e.clientX - rect.left) / width) * 100;
        const glossY = ((e.clientY - rect.top) / height) * 100;

        wrap.setAttribute("data-tilting", "");
        card.style.setProperty("--tilt-x", `${tiltX}deg`);
        card.style.setProperty("--tilt-y", `${tiltY}deg`);
        card.style.setProperty("--gloss-x", `${glossX}%`);
        card.style.setProperty("--gloss-y", `${glossY}%`);
      }

      function handleCardPointerLeave(wrap) {
        const card = wrap.querySelector(".mini-card");
        wrap.removeAttribute("data-tilting");
        if (card) {
          card.style.setProperty("--tilt-x", "0deg");
          card.style.setProperty("--tilt-y", "0deg");
          card.style.setProperty("--gloss-x", "50%");
          card.style.setProperty("--gloss-y", "50%");
        }
      }

      // Details full-card modal open
      function openModal(cardData) {
        if (!modal || !modalCard) return;

        // Style base modal background colors matching card
        modalCard.setAttribute("data-color", cardData.color);
        modalCard.className = `relative z-10 w-[388px] max-w-full aspect-[388/252] rounded-[24px] shadow-2xl transition-transform duration-300 scale-100 flex flex-col p-7 text-white font-mono uppercase border border-black/10 select-none overflow-hidden`;

        modal.querySelector("[data-modal-name]").textContent = cardData.name;
        modal.querySelector("[data-modal-date]").textContent = cardData.date;
        modal.querySelector("[data-modal-number]").textContent = `No. ${cardData.number}`;

        const img = modal.querySelector("[data-modal-signature]");
        if (img) img.src = cardData.signature;

        const ascii = modal.querySelector("[data-modal-ascii]");
        if (ascii) {
          ascii.textContent = ASCII_PRESETS[cardData.color] || "";
        }

        modal.setAttribute("data-open", "");
        modal.classList.remove("pointer-events-none");
        modal.style.opacity = "1";
      }

      function closeModal() {
        if (!modal) return;
        modal.removeAttribute("data-open");
        modal.classList.add("pointer-events-none");
        modal.style.opacity = "0";
      }

      // Render visitor cards into grid (limiting to last 15 visually)
      async function renderGallery() {
        if (!grid) return;
        grid.innerHTML = "";

        // Reset filter states
        activeFilterColor = null;

        // Fetch cards from window.visitorDb database service
        const cards = await window.visitorDb.loadCards();
        allCardsData = cards;

        // Compile and draw stats panel accordion data
        const subtitle = document.querySelector("[data-gallery-subtitle]");
        if (subtitle) {
          subtitle.textContent = `${cards.length} guests have signed in.`;
        }

        // Percentage signed cards calculation
        const defaultSigs = cards.filter(c => c.id.startsWith("seed_")).length;
        const totalUserSigs = cards.length - defaultSigs;
        const pctSigned = cards.length > 0 ? Math.round((totalUserSigs / cards.length) * 100) : 0;
        const signedPctEl = document.querySelector("[data-stats-signed-percentage]");
        if (signedPctEl) {
          signedPctEl.textContent = `${pctSigned}%`;
        }

        // Relative time of latest guest
        const latestTimeEl = document.querySelector("[data-stats-latest-time]");
        if (latestTimeEl && cards.length > 0) {
          latestTimeEl.textContent = getRelativeTime(cards[0].timestamp || cards[0].date);
        }

        // Highlight current user's card in subtitle
        const currentUserCardId = sessionStorage.getItem("gallery:current_user_card_id");
        if (currentUserCardId) {
          const userIdx = cards.findIndex(c => c.id === currentUserCardId);
          if (userIdx !== -1 && subtitle) {
            const getRankSuffix = (rank) => {
              const o = ["th", "st", "nd", "rd"];
              const c = rank % 100;
              return rank + (o[(c - 20) % 10] || o[c] || o[0]);
            };
            subtitle.textContent = `You're our ${getRankSuffix(cards.length - userIdx)} guest!`;
          }
        }

        // Draw KPI metric cards (total, this week, peak day, etc.)
        drawKpiGrid(cards);

        // Draw graph SVG timeline
        drawTimelineGraph(cards);

        // Draw color pick percentage bar rows
        drawColorStats(cards);

        // Draw pet hats aggregates
        await drawHatStats();

        // SLICE visitor cards array: Display ONLY the last 15 records in the visual grid
        const visualCards = cards.slice(0, 15);

        visualCards.forEach(cardData => {
          const wrapper = document.createElement("div");
          wrapper.className = "mini-card-wrap relative rounded-[24px] p-0.5 overflow-hidden cursor-none select-none";
          wrapper.style.boxShadow = "0 4px 24px -4px rgba(0,0,0,0.18), 0 1px 4px rgba(0,0,0,0.10)";
          wrapper.setAttribute("data-color", cardData.color);
          wrapper.setAttribute("data-cursor-bg", cardData.color);
          wrapper.setAttribute("data-mini-card-wrap", "");
          wrapper.setAttribute("data-id", cardData.id);

          // Add current user pill badge
          if (currentUserCardId === cardData.id) {
            const youPill = document.createElement("span");
            youPill.className = "mini-card-pill absolute -top-3.5 left-1/2 -translate-x-1/2 z-20 font-mono font-bold text-[10px] uppercase px-2 py-0.5 rounded-[4px] tracking-wider shadow-sm select-none pointer-events-none";
            
            // Match onboarding color selection
            const pillColors = {
              indigo: { bg: "var(--color-pink-2)", text: "#4f46e5" },
              teal: { bg: "var(--color-teal-3)", text: "var(--color-teal)" },
              green: { bg: "var(--color-green-2)", text: "var(--color-green)" },
              orange: { bg: "var(--color-orange-2)", text: "var(--color-orange)" }
            };
            const colors = pillColors[cardData.color] || pillColors.indigo;
            youPill.style.backgroundColor = colors.bg;
            youPill.style.color = colors.text;
            
            youPill.textContent = "That’s you!";
            wrapper.appendChild(youPill);
          }

          wrapper.innerHTML += `
            <div data-color="${cardData.color}" data-mini-card class="mini-card relative size-full rounded-[24px] cursor-pointer overflow-hidden shadow-md">
              <article data-color="${cardData.color}" class="library-card relative w-[388px] h-[252px] rounded-[24px] overflow-hidden p-7 flex flex-col text-white font-mono uppercase select-none">
                <!-- Braille illustrations -->
                <pre aria-hidden="true" data-for="indigo" class="library-card__flower absolute pointer-events-none whitespace-pre opacity-65 font-mono text-[14px] leading-[1.08] right-[-24px] bottom-[-14px]">${ASCII_PRESETS.indigo}</pre>
                <pre aria-hidden="true" data-for="teal" class="library-card__flower absolute pointer-events-none whitespace-pre opacity-65 font-mono text-[14px] leading-[1.08] right-[-24px] bottom-[-14px]">${ASCII_PRESETS.teal}</pre>
                <pre aria-hidden="true" data-for="green" class="library-card__flower absolute pointer-events-none whitespace-pre opacity-65 font-mono text-[12px] leading-[1.1] right-[-10px] bottom-[-10px]">${ASCII_PRESETS.green}</pre>
                <pre aria-hidden="true" data-for="orange" class="library-card__flower absolute pointer-events-none whitespace-pre opacity-65 font-mono text-[14px] leading-[1.08] right-[-24px] bottom-[-14px]">${ASCII_PRESETS.orange}</pre>

                <h2 class="font-display font-light text-[24px] leading-none normal-case relative tracking-wide">Developer Card</h2>
                
                <dl class="mt-6 flex flex-col gap-2 relative z-10">
                  <div class="flex flex-col">
                    <dt class="text-[11px] leading-none tracking-wider opacity-70">Visitor Name</dt>
                    <dd class="text-[17px] leading-none mt-1.5 font-bold truncate">${esc(cardData.name)}</dd>
                  </div>
                  <div class="flex flex-col mt-2">
                    <dt class="text-[11px] leading-none tracking-wider opacity-70">Issued on</dt>
                    <dd class="text-[17px] leading-none mt-1.5">${esc(cardData.date)}</dd>
                  </div>
                </dl>

                <div class="mt-auto flex items-end justify-between relative z-10">
                  <p class="text-[12px] leading-none opacity-70">No. ${esc(cardData.number)}</p>
                  <div class="flex items-end gap-2 grow ml-8">
                    <span class="text-[18px] leading-none font-bold">x</span>
                    <span class="block flex-1 border-b border-white/50 mb-1"></span>
                  </div>
                </div>

                <!-- SVG canvas signature drawing -->
                <img src="${cardData.signature}" class="absolute inset-0 size-full pointer-events-none z-10 select-none opacity-90" />
                
                <!-- Gloss effect layer overlay -->
                <div class="mini-gloss"></div>
              </article>
            </div>
          `;

          // Hover events for 3D tilt + gloss reflection
          wrapper.addEventListener("pointermove", (e) => handleCardPointerMove(e, wrapper));
          wrapper.addEventListener("pointerleave", () => handleCardPointerLeave(wrapper));

          // Open detailed modal on click
          wrapper.addEventListener("click", () => {
            openModal(cardData);
          });

          grid.appendChild(wrapper);
        });

        if (visualCards.length === 0) {
          const emptyMsg = document.createElement("div");
          emptyMsg.className = "col-span-full flex flex-col items-center justify-center py-16 px-4 border border-dashed border-[var(--color-bg-neutral-2)]/60 rounded-[20px] bg-[var(--color-bg-neutral)]/20 text-center";
          emptyMsg.innerHTML = `
            <svg class="text-[var(--color-ink-mute)] mb-4" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
              <path d="M16 8h.01"/>
              <path d="M12 12h.01"/>
              <path d="M8 16h.01"/>
            </svg>
            <h3 class="font-display text-lg font-medium text-[var(--color-ink)] mb-1">No developer cards yet</h3>
            <p class="font-mono text-xs text-[var(--color-ink-mute)] max-w-sm mb-4">Sign our onboarding guestbook to draw your signature and place the first card in the visitor gallery!</p>
            <a href="/onboarding" class="px-4 py-2 bg-[var(--color-ink)] hover:bg-[var(--color-ink-dim)] text-[var(--color-bg)] font-mono text-xs uppercase tracking-wider rounded-[8px] transition-colors decoration-none">Sign Guestbook →</a>
          `;
          grid.appendChild(emptyMsg);
        }

        // Fire custom event to notify SitePet of card grid updates
        window.dispatchEvent(new CustomEvent("gallery:cards-added"));
      }

      // Fisher-Yates shuffle with native Web Animations API transition
      function shuffleGalleryGrid() {
        if (!grid || isFiltering) return;
        isFiltering = true;

        const wraps = Array.from(grid.querySelectorAll("[data-mini-card-wrap]"));
        if (wraps.length === 0) {
          isFiltering = false;
          return;
        }

        const isReducedMotion = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches;
        const duration = isReducedMotion ? 0 : 380;

        // Record old bounding boxes
        const oldRects = new Map();
        wraps.forEach(w => {
          oldRects.set(w, w.getBoundingClientRect());
        });

        // Perform Fisher-Yates shuffle in DOM structure
        for (let i = wraps.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          grid.appendChild(wraps[j]); // appendChild moves node to end
        }

        // Translate nodes from old locations to new sorted locations
        let pending = 0;
        wraps.forEach(w => {
          const start = oldRects.get(w);
          const end = w.getBoundingClientRect();
          if (start) {
            const dx = start.left - end.left;
            const dy = start.top - end.top;
            if (Math.abs(dx) > 1 || Math.abs(dy) > 1) {
              pending++;
              const anim = w.animate([
                { transform: `translate3d(${dx}px, ${dy}px, 0)` },
                { transform: "translate3d(0, 0, 0)" }
              ], {
                duration: duration,
                easing: "cubic-bezier(0.22, 1, 0.36, 1)"
              });
              anim.onfinish = () => {
                pending--;
                if (pending <= 0) {
                  isFiltering = false;
                }
              };
            }
          }
        });

        if (pending === 0) {
          isFiltering = false;
        }
      }

      // Bind modal triggers
      if (closeBtn) closeBtn.addEventListener("click", closeModal);
      if (backdrop) backdrop.addEventListener("click", closeModal);
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
      });

      // Bind reset color filter button
      const resetBtn = document.querySelector("[data-stats-filter-reset]");
      if (resetBtn) resetBtn.addEventListener("click", resetFilter);

      // Bind Shuffle triggers
      if (shuffleBtn) {
        shuffleBtn.addEventListener("click", () => {
          if (isFiltering) return;
          shuffleBtn.setAttribute("data-spinning", "");
          window.dispatchEvent(new CustomEvent("gallery:shuffle"));
          shuffleGalleryGrid();
          setTimeout(() => {
            shuffleBtn.removeAttribute("data-spinning");
          }, 600);
        });
      }

      // Setup Astro View Transitions re-renders with listener cleanup to prevent memory leaks/duplicate calls
      if (window.visitorGalleryPageLoadHandler) {
        document.removeEventListener("astro:page-load", window.visitorGalleryPageLoadHandler);
      }

      window.visitorGalleryPageLoadHandler = () => {
        initStatsPanelAccordion();
        renderGallery();
      };

      document.addEventListener("astro:page-load", window.visitorGalleryPageLoadHandler);
    })();
  </script>
</body>
</html>
