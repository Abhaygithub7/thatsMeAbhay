      // Initialize accordion collapse/expand transition cleanly
      function initStatsPanelAccordion() {
        const panel = document.querySelector("[data-stats-panel]");
        const summary = panel?.querySelector("summary");
        const wrap = panel?.querySelector(".stats-body-wrap");
        if (!panel || !summary || !wrap || panel.dataset.statsWired) return;

        panel.dataset.statsWired = "1";
        const animDuration = 420;
        let isTransitioning = false;

        summary.addEventListener("click", (e) => {
          e.preventDefault();
          if (isTransitioning) return;

          if (panel.open) {
            isTransitioning = true;
            panel.setAttribute("data-collapsing", "");
            wrap.addEventListener("transitionend", function handler(event) {
              if (event.target === wrap) {
                wrap.removeEventListener("transitionend", handler);
                panel.removeAttribute("data-collapsing");
                panel.open = false;
                isTransitioning = false;
              }
            });
            setTimeout(() => {
              if (isTransitioning) {
                panel.removeAttribute("data-collapsing");
                panel.open = false;
                isTransitioning = false;
              }
            }, animDuration + 30);
          } else {
            isTransitioning = true;
            panel.setAttribute("data-expanding", "");
            panel.open = true;
            wrap.offsetHeight; // force reflow
            panel.removeAttribute("data-expanding");
            wrap.addEventListener("transitionend", function handler(event) {
              if (event.target === wrap) {
                wrap.removeEventListener("transitionend", handler);
                isTransitioning = false;
              }
            });
            setTimeout(() => {
              isTransitioning = false;
            }, animDuration + 30);
          }
        });
      }

      // Draw SVG line timeline graph of signups
      function drawTimelineGraph(cards) {
        const timelineWrap = document.querySelector("[data-stats-timeline]");
        if (!timelineWrap) return;

        // Group cards counts by day (YYYY-MM-DD)
        const dateCounts = new Map();
        cards.forEach(c => {
          const t = c.timestamp || c.date;
          const d = new Date(t);
          if (isNaN(d)) return;
          const YYYYMMDD = [
            d.getFullYear(),
            String(d.getMonth() + 1).padStart(2, "0"),
            String(d.getDate()).padStart(2, "0")
          ].join("-");
          dateCounts.set(YYYYMMDD, (dateCounts.get(YYYYMMDD) || 0) + 1);
        });

        const sortedDays = Array.from(dateCounts.keys()).sort();
        if (sortedDays.length === 0) {
          timelineWrap.innerHTML = `
            <h3 class="font-mono text-xs uppercase text-[var(--color-ink-dim)] mb-3 tracking-wide">Visitors Over Time</h3>
            <div class="h-20 flex items-center justify-center border border-dashed border-[var(--color-bg-neutral-2)]/40 rounded-[8px] bg-[var(--color-bg-neutral)]/20">
              <span class="font-mono text-[10px] text-[var(--color-ink-mute)]">No visitor signatures recorded yet.</span>
            </div>
          `;
          return;
        }

        const parseDayStr = (str) => {
          const [y, m, d] = str.split("-").map(Number);
          return new Date(y, m - 1, d);
        };
        const formatDayStr = (d) => {
          return [
            d.getFullYear(),
            String(d.getMonth() + 1).padStart(2, "0"),
            String(d.getDate()).padStart(2, "0")
          ].join("-");
        };
        const getLabel = (str) => {
          return parseDayStr(str).toLocaleDateString("en-US", { month: "short", day: "numeric" });
        };

        // Populate days gaps between earliest and latest signup date (plus 3 padding days at start)
        const timelineDays = [];
        const current = parseDayStr(sortedDays[0]);
        current.setDate(current.getDate() - 3);
        const end = parseDayStr(sortedDays[sortedDays.length - 1]);

        while (current <= end) {
          const str = formatDayStr(current);
          timelineDays.push({
            day: str,
            count: dateCounts.get(str) || 0
          });
          current.setDate(current.getDate() + 1);
        }

        if (timelineDays.length < 2) return;

        // Draw graph SVG dimensions
        const width = 600;
        const height = 80;
        const padding = 4;
        const plotHeight = height - padding * 2;
        const peakVal = Math.max(...timelineDays.map(d => d.count), 1);

        const points = timelineDays.map((d, index) => ({
          x: (index / (timelineDays.length - 1)) * width,
          y: padding + plotHeight - (d.count / peakVal) * plotHeight,
          ...d
        }));

        // Determine user theme color from onboarding
        let graphColor = "var(--color-teal)"; // default fallback
        try {
          const currentVisitor = JSON.parse(sessionStorage.getItem("current_visitor") || "null");
          if (currentVisitor && currentVisitor.color) {
            const colorVars = {
              indigo: "var(--color-pink)",
              teal: "var(--color-teal)",
              green: "var(--color-green)",
              orange: "var(--color-orange)"
            };
            graphColor = colorVars[currentVisitor.color] || "var(--color-pink)";
          }
        } catch (e) {}

        const linePath = points.map((p, index) => `${index === 0 ? "M" : "L"}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(" ");
        const fillPath = `${linePath} L${points[points.length - 1].x.toFixed(1)},${height} L${points[0].x.toFixed(1)},${height} Z`;

        const invisibleDots = points.map(p => `
          <circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="3" fill="${graphColor}" opacity="0" class="stats-line__dot" data-tip-day="${p.day}" data-tip-count="${p.count}" />
        `).join("");

        timelineWrap.innerHTML = `
          <h3 class="font-mono text-xs uppercase text-[var(--color-ink-dim)] mb-3 tracking-wide">Visitors Over Time</h3>
          <div class="flex flex-col gap-1">
            <svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" class="w-full h-20 overflow-visible" data-stats-line role="img" aria-label="Visitor signups chart over ${timelineDays.length} days, peak ${peakVal} per day">
              <!-- Fill area -->
              <path d="${fillPath}" fill="${graphColor}" opacity="0.08" />
              <!-- Stroke line -->
              <path d="${linePath}" fill="none" stroke="${graphColor}" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" opacity="0.6" />
              <!-- Hover elements -->
              <line data-stats-crosshair x1="0" y1="0" x2="0" y2="${height}" stroke="var(--color-ink-mute)" stroke-width="1" stroke-dasharray="3 3" opacity="0" />
              <circle data-stats-active-dot cx="0" cy="0" r="4.5" fill="${graphColor}" stroke="var(--color-bg)" stroke-width="2" opacity="0" />
              <!-- Invisible dots for raycasting coordinates -->
              ${invisibleDots}
            </svg>
            <div class="flex justify-between font-mono text-[9px] text-[var(--color-ink-mute)] uppercase tracking-wider mt-1">
              <span>${getLabel(timelineDays[0].day)}</span>
              <span>${getLabel(timelineDays[timelineDays.length - 1].day)}</span>
            </div>
          </div>
          <div data-stats-tooltip class="fixed px-2 py-1 rounded-[6px] bg-[var(--color-ink)] text-white font-mono text-[10px] whitespace-nowrap pointer-events-none opacity-0 transition-opacity z-50 shadow-md"></div>
        `;

        // Wire up timeline crosshair hover indicators
        const svg = timelineWrap.querySelector("[data-stats-line]");
        const tooltip = timelineWrap.querySelector("[data-stats-tooltip]");
        const crosshair = timelineWrap.querySelector("[data-stats-crosshair]");
        const activeDot = timelineWrap.querySelector("[data-stats-active-dot]");

        if (svg && tooltip && crosshair && activeDot) {
          const formatTooltipDate = (str) => {
            const [y, m, d] = str.split("-").map(Number);
            return new Date(y, m - 1, d).toLocaleDateString("en-US", { month: "short", day: "numeric" });
          };

          svg.addEventListener("mousemove", (e) => {
            const rect = svg.getBoundingClientRect();
            const percentX = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
            const dots = svg.querySelectorAll(".stats-line__dot");
            if (dots.length === 0) return;

            const index = Math.round(percentX * (dots.length - 1));
            const dot = dots[Math.max(0, Math.min(index, dots.length - 1))];
            const cx = dot.cx.baseVal.value;
            const cy = dot.cy.baseVal.value;

            crosshair.setAttribute("x1", String(cx));
            crosshair.setAttribute("x2", String(cx));
            crosshair.style.opacity = "0.3";

            activeDot.setAttribute("cx", String(cx));
            activeDot.setAttribute("cy", String(cy));
            activeDot.style.opacity = "1";

            const countVal = dot.dataset.tipCount;
            const labelStr = countVal === "1" ? "visitor" : "visitors";
            tooltip.textContent = `${formatTooltipDate(dot.dataset.tipDay)} · ${countVal} ${labelStr}`;
            tooltip.style.opacity = "1";
            tooltip.style.left = `${e.clientX}px`;
            tooltip.style.top = `${rect.top - 32}px`;
            tooltip.style.transform = "translateX(-50%)";
          });

          svg.addEventListener("mouseleave", () => {
            tooltip.style.opacity = "0";
            crosshair.style.opacity = "0";
            activeDot.style.opacity = "0";
          });
        }
      }

      // Populate color distributions stats picks rows
      function drawColorStats(cards) {
