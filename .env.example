# Firebase Configuration (Optional — the site works fully without Firebase)
# These are PUBLIC client-side keys and are safe to expose in the browser.
# They are NOT secret — Firebase security is enforced by Firestore Security Rules, not by hiding these keys.
# See: https://firebase.google.com/docs/projects/api-keys

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
